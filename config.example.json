{
  "server": {
    "port": 8000
  },
  "runtime": {
    "default_data_dir": "mock_data",
    "default_data_source": "local",
    "workspace_mode": "erp",
    "history_last": 10,
    "metrics_window_hours": 24
  },
  "paths": {
    "policy_config": "policies/active.json",
    "log_dir": "logs"
  },
  "logging": {
    "access_log": false
  },
  "security": {
    "api_token": "replace-me"
  },
  "integrations": {
    "default_asana_task": null
  },
  "live_provider": {
    "circuit_breaker": {
      "failure_threshold": 0,
      "recovery_seconds": 60
    },
    "http": {
      "base_url": "",
      "timeout_seconds": 10,
      "health_path": "/health"
    },
    "data_mapping": {
      "enabled": false,
      "datasets": {
        "orders": {
          "enabled": true,
          "field_mapping": {},
          "required_fields": [
            "order_id",
            "customer",
            "quantity"
          ],
          "type_rules": {
            "quantity": "int",
            "penalty_per_day": "float",
            "expedite_cost": "float"
          },
          "default_values": {
            "priority": "Normal",
            "customer_tier": "Standard"
          }
        },
        "materials": {
          "enabled": true,
          "field_mapping": {},
          "required_fields": [
            "order_id",
            "material",
            "required_qty",
            "available_qty"
          ],
          "type_rules": {
            "required_qty": "int",
            "available_qty": "int",
            "safety_stock": "int",
            "supplier_lead_time_days": "int",
            "unit_cost": "float",
            "supplier_reliability": "float"
          },
          "default_values": {
            "status": "Ready",
            "safety_stock": 0
          }
        }
      }
    }
  },
  "rollout": {
    "local": {
      "enabled": true
    },
    "live": {
      "enabled": false
    },
    "auto": {
      "enabled": true
    },
    "sheets": {
      "enabled": true
    }
  },
  "google_sheets": {
    "enabled": false,
    "timeout_seconds": 10,
    "datasets": {
      "orders": {
        "csv_url": "",
        "sheet_id": "",
        "gid": "0"
      },
      "materials": {
        "csv_url": "",
        "sheet_id": "",
        "gid": "0"
      },
      "work_orders": {
        "csv_url": "",
        "sheet_id": "",
        "gid": "0"
      }
    }
  },
  "alerts": {
    "enabled": false,
    "webhook_url": "",
    "cooldown_seconds": 300,
    "auto_resolve_seconds": 0
  },
  "discord": {
    "webhook_url": "",
    "allowed_user_ids": [],
    "channel_id": ""
  },
  "line": {
    "channel_access_token": "",
    "channel_secret": "",
    "allowed_user_ids": []
  },
  "guardrails": {
    "enabled": false,
    "approval_token": "",
    "operations": {
      "alerts:reset": {
        "denied": false,
        "require_approval": false
      },
      "config:reload": {
        "denied": false,
        "require_approval": false
      },
      "policy:reload": {
        "denied": false,
        "require_approval": true
      },
      "provider:select": {
        "denied": false,
        "require_approval": true
      }
    }
  },
  "auto_remediation": {
    "enabled": false,
    "hooks": {
      "circuit_breaker_recovery": {
        "trigger": "circuit_breaker_open",
        "action": "alerts:reset",
        "cooldown_seconds": 120,
        "dry_run": true
      },
      "unhealthy_alert_clear": {
        "trigger": "system_unhealthy",
        "action": "alerts:reset",
        "cooldown_seconds": 300,
        "dry_run": true
      },
      "degradation_policy_reload": {
        "trigger": "degradation_detected",
        "action": "policy:reload",
        "cooldown_seconds": 600,
        "dry_run": true
      }
    }
  },
  "automation_policy": {
    "enabled": false,
    "allowed_actions": [
      "alerts:reset",
      "config:reload",
      "policy:reload",
      "provider:fallback",
      "approval:retry"
    ],
    "denied_actions": []
  },
  "rollout_profile": {
    "global_level": "internal_only",
    "capabilities": {
      "run_query": "limited_automation",
      "team_workflows": "limited_automation",
      "provider_selection": "internal_only",
      "approval_linked_execution": "pilot_with_approval",
      "auto_remediation": "pilot_readonly"
    },
    "description": "Rollout gating profile \u2014 controls which capabilities are available at which rollout level."
  }
}
